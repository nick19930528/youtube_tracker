# 複製為 .env 後可覆寫 docker-compose 預設（勿將含真實密碼的 .env 提交版控）

WEB_PORT=8888

# 本機 Docker Compose：Web 容器內請用服務名 db（MySQL 未對主機開埠，僅容器互通）
DB_HOST=db
DB_PORT=3306
DB_NAME=youtube_tracker
DB_USER=appuser
DB_PASSWORD=123456

# MariaDB／MySQL root（僅本機開發預設，請勿用於正式環境）
MYSQL_ROOT_PASSWORD=devroot

# Cloud SQL（Cloud Run）：三種擇一即可（會優先走 Unix socket）
# 1) 直接把 DB_HOST 設成 /cloudsql/<INSTANCE_CONNECTION_NAME>
# DB_HOST=/cloudsql/project:region:instance
#
# 2) 用 DB_SOCKET 指定 socket 路徑
# DB_SOCKET=/cloudsql/project:region:instance
#
# 3) 只填連線名稱（程式會組成 /cloudsql/<name>）
# CLOUD_SQL_CONNECTION_NAME=project:region:instance

# 驗證信連結（本機 Docker 範例；正式站請改為 https://你的網域，勿結尾斜線）
APP_BASE_URL=http://localhost:8888

# PHPMailer／Gmail：MAIL_SMTP_USER 為完整信箱，MAIL_SMTP_PASSWORD 為應用程式密碼（可含空格）
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=
MAIL_SMTP_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=TubeLog
