# 複製為 .env 後可覆寫 docker-compose 預設（勿將含真實密碼的 .env 提交版控）

WEB_PORT=8080

# 正式／遠端 MySQL（與 docker-compose.yml 預設一致，可在此覆寫）
DB_HOST=35.229.213.53
DB_PORT=3306
DB_NAME=youtube_tracker
DB_USER=appuser
DB_PASSWORD=123456

# 驗證信連結（公開網址請填完整，勿結尾斜線，例如 Cloudflare Tunnel 或正式網域）
APP_BASE_URL=https://tubelog.xyz

# PHPMailer／Gmail：MAIL_SMTP_USER 為完整信箱，MAIL_SMTP_PASSWORD 為應用程式密碼（可含空格）
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=
MAIL_SMTP_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=YouTube Tracker
